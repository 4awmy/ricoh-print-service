+                         =sint16_xy %l{((200*TextXRes)/1200)}%l{((200*TextYRes)/1200)} =attr_ubyte =PageOrigin =SetPageOrigin
                }
            }
        }
    }
}

*%======== TrueType Font Download Format (PCL XL: custom feature) ========
*Feature: TrueTypeFormat
{
    *rcNameID: =RC_STR_TRUETYPE_FORMAT
