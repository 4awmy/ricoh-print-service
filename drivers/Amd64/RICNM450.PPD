 /DeferredMediaSelection true /Policies << /PageSize 0 >> >> setpagedevice"
*End

*?PageSize: "save
  currentpagedevice /PageSize get aload pop
  2 copy gt {exch} if
  (Unknown)
  <<
     [792 1224] (Tabloid)
     [612 1008] (Legal)
     [612 792]  (Letter)
     [522 756]  (Executive)
     [396 612]  (Statement)
     [842 1191] (A3)
     [595 842]  (A4)
     [420 595]  (A5)
     [297 420]  (A6)
     [729 1032] (B4-JIS)
     [516 729]  (B5)
     [576 936]  (Govt.Legal)
     [595 935]  (Folio)
     [612 936]  (FanFoldGermanLegal)
   >>
  { exch aload pop
    4 index sub abs 5 le exch 5 index sub abs 5 le and
    {exch pop exit}
    {pop}
    ifelse
  } bind forall
  = flush pop pop
  restore"
*End
*CloseUI: *PageSize

