*%
*%  Core GPD file for Ricoh PCL5c/6c printer
*%    FileName: RIAJUP4.GPD
*%    Created:  2005/05/23
*%    Modified: 2005/10/04
*%
*%    Copyright (c) 2005 Ricoh Co., Ltd.
*%    All rights reserved.
*%
*GPDFileVersion: "1.00"
*Ifdef: RI_PCLXL
*Include: "PCLXL.GPD"
*Include: "P6FONT.GPD"
*Personality: =PERSONALITY_PCLXL
*ResourceDLL: "PCLXL.DLL"
*Else:  *%%% !RI_PCLXL
*ResourceDLL: "RIAFRES.DLL"
*Endif: *%%% !RI_PCLXL

*Include: "TTFSUB.GPD"
*Include: "RIAFCMAC.GPD"
*MasterUnits: PAIR(1200, 1200)
*HelpFile: "RIAFUI.HLP"
*PrinterType: PAGE
*MaxCopies: 999
*rcInstalledOptionNameID: =RC_STR_INSTALLED
*rcNotInstalledOptionNameID: =RC_STR_NOTINSTALLED

*% #####################################################################
*%
*%  This section is for SUPPORTED FUNCTION (depend on machine) FLAG.
*%  Plugin-DLLs watch the below features
*%  , and know whether have to realize the function or not.
*%
*%======== SupportDocUiReplace (CONCEALED) ========
*Feature: SupportDocUiReplace
{
    *Name: "SupportDocUiReplace"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== AutoConfig (CONCEALED) ========
*Feature: AutoConfig
{
    *Name: "AutoConfig"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== SupportSamplePrint (CONCEALED) ========
*Feature: SupportSamplePrint
{
    *Name: "SupportSamplePrint"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== SupportSecurePrint (CONCEALED) ========
*Feature: SupportSecurePrint
{
    *Name: "SupportSecurePrint"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== SupportHoldPrint (CONCEALED) ========
*Feature: SupportHoldPrint
{
    *Name: "SupportHoldPrint"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== SupportStoredPrint (CONCEALED) ========
*Feature: SupportStoredPrint
{
    *Name: "SupportStoredPrint"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== SupportDocumentBox (CONCEALED) ========
*% *Feature: SupportDocumentBox
*% {
*%     *Name: "SupportDocumentBox"
*%     *ConcealFromUI?: TRUE
*%     *DefaultOption: ON
*%     *Option: ON
*%     {
*%        *Name: "ON"
*%     }
*% }

*%======== Support8CharPassword (CONCEALED) ========
*Feature: Support8CharPassword
{
    *Name: "Support8CharPassword"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*Ifdef: RI_P4A_MODEL
*Else:  *%%% !RI_P4A_MODEL
*%======== Hard Disk (CONCEALED) ========
*Feature: HardDisk
{
    *Name: "HardDisk"
    *ConcealFromUI?: TRUE
    *DefaultOption: Installed
    *Option: Installed
    {
        *Name: "Installed"
    }
}
*Endif: *%%% !RI_P4A_MODEL

*%======== Memory (CONCEALED) ========
*Feature: Memory
{
    *rcNameID: =PRINTER_MEMORY_DISPLAY
    *ConcealFromUI?: TRUE
    *DefaultOption: 65536KB
    *Option: 65536KB
    {
        *Name: "64MB"
        *MemoryConfigKB: PAIR(65536, 56700)
    }
}


*% #####################################################################
*% **[InputDevice]**
*Feature: InputTray3 { }
*Feature: InputTray4 { }
*Feature: LargeCapacityTray { }

*% **[OutputDevice]**
*Feature: Finisher { }
*Feature: PunchUnit { }

*% **[OtherDevice]**
*Ifdef: RI_P4A_MODEL
*Feature: Memory_HardDisk { }
*Feature: DuplexUnit { }
*Endif: *%%% !RI_P4A_MODEL

*% **[PaperAttribute]**
*Feature: PaperSize { }
*Feature: MediaType { }

*% **[DocFunction]**
*Feature: InputBin { }
*Feature: SlipSheet { }
*Feature: SlipSheetInputBin { }
*Feature: OutputBin { }
*Feature: Stapling { }
*Feature: Punching { }
*Feature: Orientation { }
*Feature: Duplex { }
*Feature: Resolution { }
*Ifdef: RI_PCLXL
*Feature: TrueTypeFormat { }
*Feature: Dither { }
*Else:  *%%% !RI_PCLXL
*Ifdef: WINNT_51
*Feature: GraphicsMode { }
*Endif: *% WINNT_51
*Feature: Halftone {}
*Endif: *%%% !RI_PCLXL
*Feature: ColorMode { }
*Ifdef: RI_PCLXL
*Else:  *%%% !RI_PCLXL
*Feature: ColorMap {}
*Endif: *%%% !RI_PCLXL
*% #####################################################################


*Ifdef: RI_P4A_MODEL
*%======== Memory & Hard Disk (installable option) ========
*Feature: Memory_HardDisk
{
    *rcNameID: =RC_STR_MEMORY_HARDDISK
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: 256MB_NotInstalled
    *Option: 256MB_NotInstalled
    {
        *rcNameID: =RC_STR_256MB_NOTINSTALLED
        *DisabledFeatures: LIST(Collate)
    }
    *Option: 256MB_Installed
    {
        *rcNameID: =RC_STR_256MB_INSTALLED
    }
    *Option: 320MBorMore_NotInstalled
    {
        *rcNameID: =RC_STR_320MBORMORE_NOTINSTALLED
    }
    *Option: 320MBorMore_Installed
    {
        *rcNameID: =RC_STR_320MBORMORE_INSTALLED
    }
}

*%======== Duplex Unit (installable option) ========
*Feature: DuplexUnit
{
    *rcNameID: =RC_STR_DUPLEX_UNIT
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *DisabledFeatures: LIST(Duplex)
        *Constraints: LIST( Duplex.VERTICAL,
+                           Duplex.HORIZONTAL )
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}
*Endif: *%%% !RI_P4A_MODEL

*%======== Finisher (installable option) ========
*Feature: Finisher
{
    *rcNameID: =RC_STR_FINISHER
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.FinisherShiftTray1
        *Constraints: OutputBin.FinisherShiftTray2
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: OutputBin.FinisherBookletTray
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and3holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and4holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2holesJP
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.4holesEU
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.4holesNE
*Endif: *%%% !RICOH_AUTOCONFIG
    }
    *Option: Finisher2000
    {
        *rcNameID: =RC_STR_2TRAY_FINISHER
        *Constraints: PunchUnit.2holesJP
        *Constraints: PunchUnit.4holesEU
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: OutputBin.FinisherBookletTray
        *Constraints: Stapling.Booklet
    }
    *Option: BookletFinisher
    {
        *rcNameID: =RC_STR_BOOKLET_FINISHER
        *Constraints: PunchUnit.2and4holes
        *Constraints: OutputBin.FinisherShiftTray1
        *Constraints: OutputBin.FinisherShiftTray2
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopRightSlant
    }
}

*%======== Punch Unit (installable option) ========
*Feature: PunchUnit
{
    *rcNameID: =RC_STR_PUNCH_UNIT
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and3holes
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and4holes
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_4
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 2holesJP
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_JP
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 4holesEU
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_4_EU
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 4holesNE
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_4_NE
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
}

*%======== Input Tray3 (installable option) ========
*Feature: InputTray3
{
    *rcNameID: =RC_STR_TRAY3
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: InputBin.Tray3
        *Constraints: SlipSheetInputBin.Tray3
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}

*%======== Input Tray4 (installable option) ========
*Feature: InputTray4
{
    *rcNameID: =RC_STR_TRAY4
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: InputBin.Tray4
        *Constraints: SlipSheetInputBin.Tray4
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: InputTray3.NotInstalled
*Endif: *%%% !RICOH_AUTOCONFIG
    }
}

*%======== LargeCapacityTray (installable option) ========
*Feature: LargeCapacityTray
{
    *rcNameID: =RC_STR_LARGE_CAPACITY_TRAY
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: InputBin.LARGECAPACITY
        *Constraints: SlipSheetInputBin.LARGECAPACITY
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}

*%======== Orientation ========
*Feature: Orientation
{
    *rcNameID: =ORIENTATION_DISPLAY
    *DefaultOption: PORTRAIT
    *Option: PORTRAIT
    {
        *rcNameID: =PORTRAIT_DISPLAY
    }
    *Option: LANDSCAPE_CC90
    {
        *rcNameID: =LANDSCAPE_DISPLAY
    }
}

*%======== Duplex ========
*Feature: Duplex
{
    *rcNameID: =TWO_SIDED_PRINTING_DISPLAY
    *DefaultOption: NONE
    *Option: NONE
    {
        *rcNameID: =NONE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=OFF<0A>"
        }
    }
    *Option: VERTICAL
    {
        *rcNameID: =FLIP_ON_LONG_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=LONGEDGE<0A>"
        }
    }
    *Option: HORIZONTAL
    {
        *rcNameID: =FLIP_ON_SHORT_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=SHORTEDGE<0A>"
        }
    }
}




*%======== OutputBin ========
*Feature: OutputBin
{
    *rcNameID: =OUTPUTBIN_DISPLAY
    *HelpIndex: =HLP_OUTPUTBIN
    *DefaultOption: PrinterDefault
    *Option: PrinterDefault
    {
        *rcNameID: =RC_STR_PRINTER_DEFAULT
    }
    *Option: StandardTray
    {
        *rcNameID: =RC_STR_STANDARD_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=UPPER<0A>"
        }
        *DisabledFeatures: LIST(Stapling)
        *DisabledFeatures: LIST(Punching)
        *Constraints: Stapling.TopLeft
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopRight
        *Constraints: Stapling.TopRightSlant
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
        *Constraints: Stapling.Booklet
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: ExternalTray
    {
        *rcNameID: =RC_STR_EXTERNAL_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=LOWER<0A>"
        }
        *DisabledFeatures: LIST(Stapling)
        *DisabledFeatures: LIST(Punching)
        *Constraints: Stapling.TopLeft
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopRight
        *Constraints: Stapling.TopRightSlant
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
        *Constraints: Stapling.Booklet
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
        *Constraints: Duplex.VERTICAL
        *Constraints: Duplex.HORIZONTAL
    }
    *Option: FinisherShiftTray1
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY1
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERPROOF<0A>"
        }
        *DisabledFeatures: LIST(Stapling)
        *Constraints: Stapling.TopLeft
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopRight
        *Constraints: Stapling.TopRightSlant
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
        *Constraints: Stapling.Booklet
    }
    *Option: FinisherShiftTray2
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY2
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
        }
        *Constraints: Stapling.Booklet
    }
    *Option: FinisherShiftTray
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
        }
        *Constraints: Stapling.Booklet
    }
    *Option: FinisherBookletTray
    {
        *rcNameID: =RC_STR_BOOKLET_FINISHER_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
	    *Cmd: "@PJL SET OUTBIN=FINISHERBOOKLET<0A>"
        }
        *DisabledFeatures: LIST(Punching)
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
}

*%======== Collate ========
*Feature: Collate
{
    *Name: "Collated"       *%%% This string isn't used in UI.
    *DefaultOption: OFF
    *Option: ON
    {
        *rcNameID: =ON_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_50
            *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>"
        }
    }
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_50
*%          *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
            *CallbackID: =CMD_COLLATE_JOBOFFSET_OFF
            *Params: LIST(NumOfCopies)
        }
    }
}

*%======== Stapling ========
*Macros: CmdStrings_Stapling
{
    PRECMD_STAPLE: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERSHIFT<0A>@PJL SET JOBOFFSET=OFF<0A>"
    PRECMD_STAPLE_BOOKLET_TRAY: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERBOOKLET<0A>@PJL SET JOBOFFSET=OFF<0A>"
}
*Feature: Stapling
{
    *rcNameID: =RC_STR_STAPLE
    *HelpIndex: =HLP_STAPLE
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_60
            *Cmd: "@PJL SET STAPLE=OFF<0A>"
        }
    }
    *Option: TopLeft
    {
        *rcNameID: =RC_STR_TOP_LEFT
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
        }
    }
    *Option: TopRight
    {
        *rcNameID: =RC_STR_TOP_RIGHT
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
        }
    }
    *Option: Left2
    {
        *rcNameID: =RC_STR_LEFT2
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
        }
    }
    *Option: Top2
    {
        *rcNameID: =RC_STR_TOP2
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
        }
    }
    *Option: Right2
    {
        *rcNameID: =RC_STR_RIGHT2
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
        }
    }
    *Option: TopLeftSlant
    {
        *rcNameID: =RC_STR_TOP_LEFT_SLANT
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=LEFTTOPSLANTPORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFTTOPSLANTPORT<0A>"
                }
            }
        }
    }
    *Option: TopRightSlant
    {
        *rcNameID: =RC_STR_TOP_RIGHT_SLANT
        *switch: OutputBin
        {
            *case: FinisherBookletTray
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=RIGHTTOPSLANTPORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHTTOPSLANTPORT<0A>"
                }
            }
        }
    }
    *Option: Booklet
    {
        *rcNameID: =RC_STR_BOOKLET
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_60
            *Cmd: =PRECMD_STAPLE_BOOKLET_TRAY "@PJL SET STAPLE=BOOKLET<0A>"
        }
    }
}

*%======== Punching (custom feature) ========
*Macros: CmdStrings_Punching
{
    PRECMD_PUNCH: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
    PRECMD_PUNCH_PROOF: "@PJL SET OUTBIN=FINISHERPROOF<0A>"
}
*Feature: Punching
{
    *rcNameID: =RC_STR_PUNCH
    *HelpIndex: =HLP_PUNCH
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_70
            *Cmd: "@PJL SET PUNCH=OFF<0A>"
        }
    }
    *Option: Left2
    {
        *rcNameID: =RC_STR_LEFT2
        *switch: PunchUnit
        {
            *case: 2and3holes
            {
                *switch: OutputBin
                {
                    *case: FinisherShiftTray1
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH_PROOF "@PJL SET PUNCH=LEFTPORT<0A>@PJL SET PUNCHHOLE=US2<0A>"
                        }
                    }
                    *default:
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH "@PJL SET PUNCH=LEFTPORT<0A>@PJL SET PUNCHHOLE=US2<0A>"
                        }
                    }
                }
            }
            *default:
            {
                *switch: OutputBin
                {
                    *case: FinisherShiftTray1
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH_PROOF "@PJL SET PUNCH=LEFTPORT<0A>@PJL SET PUNCHHOLE=JP2<0A>"
                        }
                    }
                    *default:
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH "@PJL SET PUNCH=LEFTPORT<0A>@PJL SET PUNCHHOLE=JP2<0A>"
                        }
                    }
                }
            }
        }
    }
