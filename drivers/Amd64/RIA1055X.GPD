                *Command: CmdStartJob
                {
                    *Order: JOB_SETUP.10
                    *CallbackID: =CMD_STARTJOB_PORT_AUTOTRAYCHANGE_ON
                }
            }
            *default:
            {
                *Command: CmdStartJob
                {
                    *Order: JOB_SETUP.10
                    *CallbackID: =CMD_STARTJOB_PORT_AUTOTRAYCHANGE_OFF
                }
            }
        }
    }
    *case: LANDSCAPE_CC90
    {
        *switch: InputBin
        {
            *case: AUTO
            {
                *Command: CmdStartJob
                {
                    *Order: JOB_SETUP.10
                    *CallbackID: =CMD_STARTJOB_LAND_AUTOTRAYCHANGE_ON
                }
            }
            *default:
            {
                *Command: CmdStartJob
                {
