*%======== Hard Disk (CONCEALED) ========
*Feature: HardDisk
{
    *Name: "HardDisk"
    *ConcealFromUI?: TRUE
    *DefaultOption: Installed
    *Option: Installed
    {
        *Name: "Installed"
    }
}

*%======== Memory ========
*Feature: Memory
{
    *rcNameID: =PRINTER_MEMORY_DISPLAY
    *DefaultOption: 32768KB
    *Option: 32768KB
    {
        *Name: "32MB"
        *MemoryConfigKB: PAIR(32768, 28350)
    }
}


*% #####################################################################


*%======== Finisher (custom feature) ========
*Feature: Finisher
{
    *rcNameID: =RC_STR_FINISHER
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.FinisherProofTray
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopLeftVertical
        *Constraints: Stapling.TopLeftHorizontal
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: PunchUnit.Installed
        *DisabledFeatures: LIST(Stapling)
    }
    *Option: Finisher3000M
    {
        *rcNameID: =RC_STR_FINISHER_3000M
        *Constraints: OutputBin.ExternalTray
    }
}

*%======== Booklet Finisher (custom feature) ========
*% NOTE:
*% Booklet Finisher is separated from above Finisher feature, because
*% UI plugin search this feature to make Ricoh printprocessor set page order
*% for lastprintout-outside type Booklet Finisher.

*Feature: BookletFinisher
{
*% NOTE:
*% Use english strings because vendor-released riafui3.dll has only English strings.
*% (Inboxed riafres.dll (GPD resource dll) is localized.)
*Ifdef: RI_VENDORRELEASE
    *Name: "Booklet Finisher"
*Else:  *%%% !RI_VENDORRELEASE
    *rcNameID: 400          *%%% "Booklet Finisher"
*Endif: *%%% !RI_VENDORRELEASE
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: 329
*Ifdef: RI_PRINTPROCESSOR
        *Constraints: OutputBin.BookletFinisherTray
        *Constraints: Stapling.Booklet
*Endif: *%%% RI_PRINTPROCESSOR
    }
    *Option: Installed
    {
        *rcNameID: 330
        *Constraints: Finisher.Finisher3000M
        *Constraints: OutputBin.ExternalTray
        *Constraints: PunchUnit.Installed
    }
}

*%======== Punch Unit (custom feature) ========
*Feature: PunchUnit
{
    *rcNameID: =RC_STR_PUNCH_UNIT
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: Punching.Left
        *Constraints: Punching.Top
    }
    *Option: Installed
    {
        *rcNameID: 330
    }
}

*%======== Orientation ========
*Feature: Orientation
{
    *rcNameID: =ORIENTATION_DISPLAY
    *DefaultOption: PORTRAIT
    *Option: PORTRAIT
    {
        *rcNameID: =PORTRAIT_DISPLAY
    }
    *Option: LANDSCAPE_CC90
    {
        *rcNameID: =LANDSCAPE_DISPLAY
    }
}

*%======== Emit Orientation Command (CONCEALED) ========
*% NOTE:
*% Need to write "*NoPageEject?: TRUE" in orientation command emission
*% to print mixed-orientation document in duplex correctly. (2002/08/01)

*Feature: EmitOrientationCommand
{
    *Name: "Emit Orientation Command"
    *ConcealFromUI?: TRUE
    *DefaultOption: Option1
    *Option: Option1
    {
        *Name: "Emit Orientation Command"
        *switch: Orientation
        {
            *case: PORTRAIT
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.25
                    *NoPageEject?: TRUE
                    *Cmd: =PCL5_ORIENTATION_PORT
                }
            }
            *case: LANDSCAPE_CC90
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.25
                    *NoPageEject?: TRUE
                    *Cmd: =PCL5_ORIENTATION_LAND
                }
            }
        }
    }
}

*%======== InputBin ========
*Feature: InputBin
{
    *rcNameID: =PAPER_SOURCE_DISPLAY
    *DefaultOption: AUTO
    *Option: AUTO
    {
        *rcNameID: =RC_STR_AUTO_SELECT_BY_PRINTER
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *Cmd: "<1B>&l7H"
        }
    }
    *Option: BypassTray
    {
        *rcNameID: =RC_STR_BYPASS_TRAY
        *OptionID: 4            *%%% DMBIN_MANUAL
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *NoPageEject?: TRUE
            *Cmd: "<1B>&l2H"
        }
    }
    *Option: LARGECAPACITY
    {
        *rcNameID: =RC_STR_LARGE_CAPACITY_TRAY
        *Installable?: TRUE
        *rcInstallableFeatureNameID: =RC_STR_LARGE_CAPACITY_TRAY
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *NoPageEject?: TRUE
            *Cmd: "<1B>&l5H"
        }
    }
    *Option: Tray1
    {
        *rcNameID: =RC_STR_TRAY1
        *OptionID: 1            *%%% DMBIN_UPPER
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *NoPageEject?: TRUE
            *Cmd: "<1B>&l8H"
        }
    }
    *Option: Tray2
    {
        *rcNameID: =RC_STR_TRAY2
        *OptionID: 3            *%%% DMBIN_MIDDLE
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *NoPageEject?: TRUE
            *Cmd: "<1B>&l1H"
        }
    }
    *Option: Tray3
    {
        *rcNameID: =RC_STR_TRAY3
        *OptionID: 2            *%%% DMBIN_LOWER
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.30
            *NoPageEject?: TRUE
            *Cmd: "<1B>&l4H"
        }
    }
}

*%======== MediaType ========
*Feature: MediaType
{
    *rcNameID: =MEDIA_TYPE_DISPLAY
    *DefaultOption: STANDARD
    *Option: STANDARD
    {
        *rcNameID: =PLAIN_PAPER_DISPLAY
        *switch: InputBin
        {
            *case: BypassTray
            {
                *Command: CmdSelect
                {
                    *Order: JOB_SETUP.80
                    *Cmd: "@PJL SET FUSERCONTROL=PLAINPAPER<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.35
                    *Cmd: "<1B>&n6WdPlain"
                }
            }
        }
    }
    *Option: TRANSPARENCY
    {
        *rcNameID: =TRANSPARENCY_DISPLAY
        *Command: CmdSelect
        {
            *Order: JOB_SETUP.80
            *Cmd: "@PJL SET FUSERCONTROL=TRANSPARENCY<0A>"
        }
    }
    *Option: Thick
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Thick"
*Else:
        *rcNameID: =RC_STR_THICK
*Endif:
        *switch: InputBin
        {
            *case: BypassTray
            {
                *Command: CmdSelect
                {
                    *Order: JOB_SETUP.80
                    *Cmd: "@PJL SET FUSERCONTROL=THICK<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.35
                    *Cmd: "<1B>&n6WdThick"
                }
            }
        }
    }
    *Option: Recycled
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Recycled"
*Else:
        *rcNameID: =RC_STR_RECYCLED
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n9WdRecycled"
        }
    }
    *Option: Special
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Special"
*Else:
        *rcNameID: =RC_STR_SPECIAL
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n8WdSpecial"
        }
    }
    *Option: Translucent
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Translucent"
*Else:
        *rcNameID: =RC_STR_TRANSLUCENT
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n12WdTranslucent"
        }
    }
    *Option: Tabstock
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Tab Stock"
*Else:
        *rcNameID: =RC_STR_TABSTOCK
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n9WdTabstock"
        }
    }
    *Option: Usercolor1
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "User Color 1"
*Else:
        *rcNameID: =RC_STR_USERCOLOR1
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n13WdUser Color 1"
        }
    }
    *Option: Usercolor2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "User Color 2"
*Else:
        *rcNameID: =RC_STR_USERCOLOR2
*Endif:
        *Command: CmdSelect
        {
            *Order: DOC_SETUP.35
            *Cmd: "<1B>&n11WdUser Color 2"
        }
    }
}
*InvalidCombination: LIST(InputBin.AUTO, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.LARGECAPACITY, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.Tray1, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.Tray2, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.Tray3, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Recycled)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Special)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Translucent)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Tabstock)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Usercolor1)
*InvalidCombination: LIST(InputBin.BypassTray, MediaType.Usercolor2)

*%======== Resolution ========
*Feature: Resolution
{
    *rcNameID: =RESOLUTION_DISPLAY
    *DefaultOption: 600dpi
    *Option: 600dpi
    {
        *rcNameID: =RC_STR_600DPI
        *DPI: PAIR(600, 600)
        *TextDPI: PAIR(600, 600)
        *MinStripBlankPixels: 32
        EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
        *SpotDiameter: 100
        *Command: CmdBeginRaster { *Cmd : "<1B>*r1A" }
        *Command: CmdEndRaster { *Cmd : "<1B>*rB" }
        *Command: CmdSendBlockData { *Cmd : "<1B>*b" %d{NumOfDataBytes}"W" }
        *Command: CmdSelect
        {
            *Order: JOB_SETUP.90
            *Cmd: "@PJL SET RESOLUTION=600<0A>@PJL ENTER LANGUAGE=PCL<0A1B>E<1B>*t600R"
        }
    }
    *Option: 300dpi
    {
        *rcNameID: =RC_STR_300DPI
        *DPI: PAIR(300, 300)
        *TextDPI: PAIR(300, 300)
        *MinStripBlankPixels: 32
        EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
        *SpotDiameter: 100
        *Command: CmdBeginRaster { *Cmd : "<1B>*r1A" }
        *Command: CmdEndRaster { *Cmd : "<1B>*rB" }
        *Command: CmdSendBlockData { *Cmd : "<1B>*b" %d{NumOfDataBytes}"W" }
        *Command: CmdSelect
        {
            *Order: JOB_SETUP.90
            *Cmd: "@PJL SET RESOLUTION=300<0A>@PJL ENTER LANGUAGE=PCL<0A1B>E<1B>*t300R"
        }
    }
}

