*InvalidCombination: LIST(InputBin.LARGECAPACITY, PaperSize.EXECUTIVE)
*InvalidCombination: LIST(InputBin.LARGECAPACITY, PaperSize.12x18)
*InvalidCombination: LIST(InputBin.LARGECAPACITY, PaperSize.CUSTOMSIZE)

*InvalidCombination: LIST(InputBin.Tray1, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.Tray1, MediaType.Labels)
*InvalidCombination: LIST(InputBin.Tray1, MediaType.Translucent)
*InvalidCombination: LIST(InputBin.Tray2, MediaType.TRANSPARENCY)
*InvalidCombination: LIST(InputBin.Tray2, MediaType.Labels)
*InvalidCombination: LIST(InputBin.Tray2, MediaType.Translucent)
*InvalidCombination: LIST(InputBin.Tray3, MediaType.TRANSPARENCY)
