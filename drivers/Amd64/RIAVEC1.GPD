*%======== Memory (CONCEALED) ========
*Feature: Memory
{
    *rcNameID: =PRINTER_MEMORY_DISPLAY
    *ConcealFromUI?: TRUE
    *DefaultOption: 65536KB
    *Option: 65536KB
    {
        *Name: "64MB"
        *MemoryConfigKB: PAIR(65536, 56700)
    }
}


*% #####################################################################
*%======== Feature Prototype ========
*% **[InputDevice]**
*Feature: LargeCapacityTray {}

*% **[OutputDevice]**
*Feature: ExternalTray {}
*Feature: Finisher {}
*Feature: Mailbox {}
*Feature: PunchUnit {}

*% **[OtherDevice]**
*% **[PaperAttribute]**
*Feature: PaperSize {}
*Feature: MediaType {}

*% **[DocFunction]**
*Feature: InputBin {}
*Feature: SlipSheet {}
*Feature: SlipSheetInputBin {}
*Feature: OutputBin {}
*Feature: Stapling {}
*Feature: Punching {}
*Feature: Orientation {}
*Feature: Duplex {}
*Feature: Resolution {}
*Ifdef: RI_PCLXL
*Feature: TrueTypeFormat {}
*Else:  *%%% !RI_PCLXL
*Ifdef: WINNT_51
*Feature: GraphicsMode {}
*Endif: *% WINNT_51
*Feature: Gradation {}
*Feature: Halftone {}
*Endif: *%%% !RI_PCLXL
*Feature: ColorMode {}
*Ifdef: RI_PCLXL
*Else:  *%%% !RI_PCLXL
*Feature: ColorMap {}
*Endif: *%%% !RI_PCLXL
*% #####################################################################


*%======== Finisher (installable option) ========
*Feature: Finisher
{
    *rcNameID: =RC_STR_FINISHER
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.FinisherBookletTray
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: OutputBin.FinisherUpperTray
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and3holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and4holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.4holesEU
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.4holesNE
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2holesUS
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.3holesUS
*Endif: *%%% !RICOH_AUTOCONFIG
    }
    *Option: Finisher3000B
    {
        *rcNameID: =RC_STR_FINISHER_3000B
        *Constraints: ExternalTray.Installed
        *Constraints: Mailbox.Installed
        *Constraints: OutputBin.ExternalTray
        *Constraints: OutputBin.FinisherBookletTray
        *Constraints: OutputBin.OutputBin1
        *Constraints: OutputBin.OutputBin2
        *Constraints: OutputBin.OutputBin3
        *Constraints: OutputBin.OutputBin4
        *Constraints: OutputBin.OutputBin5
        *Constraints: OutputBin.OutputBin6
        *Constraints: OutputBin.OutputBin7
        *Constraints: OutputBin.OutputBin8
        *Constraints: OutputBin.OutputBin9

    }
    *Option: FinisherMECBK
    {
        *rcNameID: =RC_STR_FINISHER_MEC_BK
        *Constraints: ExternalTray.Installed
        *Constraints: PunchUnit.2holesUS
        *Constraints: PunchUnit.3holesUS
        *Constraints: PunchUnit.4holesEU
        *Constraints: OutputBin.ExternalTray
    }
    *Option: FinisherMEC
    {
        *rcNameID: =RC_STR_FINISHER_MEC
        *Constraints: ExternalTray.Installed
        *Constraints: PunchUnit.2holesUS
        *Constraints: PunchUnit.3holesUS
        *Constraints: PunchUnit.4holesEU
        *Constraints: OutputBin.ExternalTray
        *Constraints: OutputBin.FinisherBookletTray
    }
}

*%======== Punch Unit (installable option) ========
*Feature: PunchUnit
{
    *rcNameID: =RC_STR_PUNCH_UNIT
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and3holes
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and4holes
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_4
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 2holesUS
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_2_US
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 3holesUS
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_3_US
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
    }
    *Option: 4holesEU
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_4_EU
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 4holesNE
    {
        *rcNameID: =RC_STR_PUNCH_UNIT_4_NE
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
}

*%======== Mailbox (installable option) ========
*Feature: Mailbox
{
    *rcNameID: =RC_STR_MAILBOX
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.OutputBin1
        *Constraints: OutputBin.OutputBin2
        *Constraints: OutputBin.OutputBin3
        *Constraints: OutputBin.OutputBin4
        *Constraints: OutputBin.OutputBin5
        *Constraints: OutputBin.OutputBin6
        *Constraints: OutputBin.OutputBin7
        *Constraints: OutputBin.OutputBin8
        *Constraints: OutputBin.OutputBin9
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
        *Constraints: ExternalTray.Installed
    }
}

*%======== External Output Tray (installable option) ========
*Feature: ExternalTray
{
    *rcNameID: =RC_STR_COPY_TRAY
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.ExternalTray
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
        *Constraints: PunchUnit.2holesUS
        *Constraints: PunchUnit.3holesUS
        *Constraints: PunchUnit.4holesEU
        *Constraints: PunchUnit.4holesNE
        *Constraints: PunchUnit.2and3holes
        *Constraints: PunchUnit.2and4holes
        *Constraints: OutputBin.FinisherBookletTray
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: OutputBin.FinisherUpperTray
        *Constraints: OutputBin.OutputBin1
        *Constraints: OutputBin.OutputBin2
        *Constraints: OutputBin.OutputBin3
        *Constraints: OutputBin.OutputBin4
        *Constraints: OutputBin.OutputBin5
        *Constraints: OutputBin.OutputBin6
        *Constraints: OutputBin.OutputBin7
        *Constraints: OutputBin.OutputBin8
        *Constraints: OutputBin.OutputBin9
    }
}

*%======== LargeCapacityTray (installable option) ========
*Feature: LargeCapacityTray
{
    *rcNameID: =RC_STR_LARGE_CAPACITY_TRAY
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: InputBin.LARGECAPACITY
        *Constraints: SlipSheetInputBin.LARGECAPACITY
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}

*%======== Orientation ========
*Feature: Orientation
{
    *rcNameID: =ORIENTATION_DISPLAY
    *DefaultOption: PORTRAIT
    *Option: PORTRAIT
    {
        *rcNameID: =PORTRAIT_DISPLAY
    }
    *Option: LANDSCAPE_CC90
    {
        *rcNameID: =LANDSCAPE_DISPLAY
    }
}

*%======== Duplex ========
*Feature: Duplex
{
    *rcNameID: =TWO_SIDED_PRINTING_DISPLAY
    *DefaultOption: NONE
    *Option: NONE
    {
        *rcNameID: =NONE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=OFF<0A>"
        }
    }
    *Option: VERTICAL
    {
        *rcNameID: =FLIP_ON_LONG_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=LONGEDGE<0A>"
        }
    }
    *Option: HORIZONTAL
    {
        *rcNameID: =FLIP_ON_SHORT_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=SHORTEDGE<0A>"
        }
    }
}

*%======== OutputBin ========
*Feature: OutputBin
{
    *rcNameID: =OUTPUTBIN_DISPLAY
    *HelpIndex: =HLP_OUTPUTBIN
    *DefaultOption: PrinterDefault
    *Option: PrinterDefault
    {
        *rcNameID: =RC_STR_PRINTER_DEFAULT
    }
    *Option: ExternalTray
    {
        *rcNameID: =RC_STR_COPY_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=UPPER<0A>"
        }
        *DisabledFeatures: LIST(Stapling)
        *DisabledFeatures: LIST(Punching)
        *Constraints: Stapling.TopLeft
        *Constraints: Stapling.TopLeftSlant
        *Constraints: Stapling.TopRight
        *Constraints: Stapling.TopRightSlant
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: FinisherUpperTray
    {
        *rcNameID: =RC_STR_FINISHER_UPPER_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERPROOF<0A>"
