*%======== Collate ========
*Feature: Collate
{
    *Name: "Collated"       *%%% This string isn't used in UI.
    *DefaultOption: OFF
    *Option: ON
    {
        *rcNameID: =ON_DISPLAY
        *switch: Finisher
        {
            *case: NotInstalled
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
                    *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET JOBOFFSET=ROTATE<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
                    *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET JOBOFFSET=SHIFT<0A>"
                }
            }
        }
    }
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *switch: Finisher
        {
            *case: NotInstalled
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
*%                  *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
                    *CallbackID: =CMD_COLLATE_JOBOFFSET_ROTATE
                    *Params: LIST(NumOfCopies)
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
*%                  *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
                    *CallbackID: =CMD_COLLATE_JOBOFFSET_SHIFT
                    *Params: LIST(NumOfCopies)
                }
            }
        }
    }
}

*%======== Stapling ========
*Macros: CmdStrings_Stapling
{
    PRECMD_STAPLE: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERSHIFT<0A>@PJL SET JOBOFFSET=OFF<0A>"
    PRECMD_STAPLE_BOOKLET_TRAY: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERBOOKLET<0A>@PJL SET JOBOFFSET=OFF<0A>"
}
*Feature: Stapling
{
    *rcNameID: =RC_STR_STAPLE
    *HelpIndex: =HLP_STAPLE
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_60
            *Cmd: "@PJL SET STAPLE=OFF<0A>"
        }
    }
    *Option: TopLeft
    {
        *rcNameID: =RC_STR_TOP_LEFT
        *Command: CmdSelect
        {
