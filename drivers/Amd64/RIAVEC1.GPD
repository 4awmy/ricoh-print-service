*GPDFileVersion: "1.00"
*Ifdef: RI_PCLXL
*Include: "PCLXL.GPD"
*Include: "P6FONT.GPD"
*Personality: =PERSONALITY_PCLXL
*ResourceDLL: "PCLXL.DLL"
*Else:  *%%% !RI_PCLXL
*ResourceDLL: "RIAFRES.DLL"
*Endif: *%%% !RI_PCLXL

*Include: "TTFSUB.GPD"
*Include: "RIAFCMAC.GPD"
*MasterUnits: PAIR(1200, 1200)
*HelpFile: "RIAFUI.HLP"
*PrinterType: PAGE
*MaxCopies: 999
*rcInstalledOptionNameID: =RC_STR_INSTALLED
*rcNotInstalledOptionNameID: =RC_STR_NOTINSTALLED

*% #####################################################################
*%
*%  This section is for SUPPORTED FUNCTION (depend on machine) FLAG.
*%  Plugin-DLLs watch the below features
*%  , and know whether have to realize the function or not.
*%
*%======== SupportDocUiReplace (CONCEALED) ========
*Feature: SupportDocUiReplace
{
    *Name: "SupportDocUiReplace"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

*%======== AutoConfig (CONCEALED) ========
*Feature: AutoConfig
{
    *Name: "AutoConfig"
    *ConcealFromUI?: TRUE
    *DefaultOption: ON
    *Option: ON
    {
        *Name: "ON"
    }
}

