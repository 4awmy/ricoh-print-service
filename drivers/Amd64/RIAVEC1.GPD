*%======== PaperSize (PCL5c) ========
*Feature: PaperSize
{
    *rcNameID: =PAPER_SIZE_DISPLAY
    *DefaultOption: LETTER
    *Option: 12x18
    {
        *rcNameID: =RC_STR_12X18
        *PageDimensions: PAIR(14400, 21600)
        *switch: Orientation
        {
            *case: PORTRAIT
            {
                *PrintableArea: PAIR(13824, 20408)
                *PrintableOrigin: PAIR(284, 200)
                *CursorOrigin: PAIR(284, 200)
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.40
                    *Cmd: "<1B>&l2043a8c1E<1B>*p0x0Y<1B>*c0t"
+                         %d{((13824*6+5)/10)}"x" %d{((20408*6+5)/10)}"Y"
                }
            }
            *case: LANDSCAPE_CC90
            {
                *PrintableArea: PAIR(14000, 20320)
                *PrintableOrigin: PAIR(200, 640)
