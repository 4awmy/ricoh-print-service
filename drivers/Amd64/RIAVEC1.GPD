*%======== Dither (PCL XL: custom feature) ========
*Feature: Dither
{
    *rcNameID: =RC_STR_DITHER_QUALITY
    *HelpIndex: =HLP_DITHER
    *DefaultOption: High
    *Option: High
    {
        *rcNameID: =RC_STR_HIGH
        *Command: CmdSelect
        {
            *Order: PAGE_SETUP.26
            *Cmd: =ubyte "<00>" =attr_ubyte =RI_DitheringText
+                 =ubyte "<02>" =attr_ubyte =RI_DitheringGraphics
+                 =ubyte "<02>" =attr_ubyte =RI_DitheringPhoto
+                 =SetHalftoneMethod
        }
    }
    *Option: Low
    {
        *rcNameID: =RC_STR_LOW
        *Command: CmdSelect
        {
            *Order: PAGE_SETUP.26
            *Cmd: =ubyte "<00>" =attr_ubyte =RI_DitheringText
+                 =ubyte "<00>" =attr_ubyte =RI_DitheringGraphics
+                 =ubyte "<00>" =attr_ubyte =RI_DitheringPhoto
+                 =SetHalftoneMethod
        }
    }
}

*%======== ColorMode (PCLXL) ========
*Feature: ColorMode
{
    *rcNameID: =COLOR_PRINTING_MODE_DISPLAY
    *DefaultOption: 24bpp
    *Option: 24bpp
    {
        *rcNameID: =24BPP_DISPLAY
        *DevNumOfPlanes: 1
        *DevBPP: 24
        *DrvBPP: 24
        *PaletteSize: 256
        *PaletteProgrammable? : TRUE
        *Command: CmdDefinePaletteEntry { *Cmd: "" }
    }
    *Option: Mono
    {
        *rcNameID: =MONO_DISPLAY
        *DevNumOfPlanes: 1
        *DevBPP: 24
        *DrvBPP: 24
        *Color? : FALSE
        *PaletteSize: 1
        *PaletteProgrammable? : TRUE
        *Command: CmdDefinePaletteEntry { *Cmd: "" }
    }
}

*%======== TrueType Font Download Format (PCL XL: custom feature) ========
*Feature: TrueTypeFormat
{
    *rcNameID: =RC_STR_TRUETYPE_FORMAT
    *HelpIndex: =HLP_TRUETYPE_FORMAT
    *DefaultOption: TTFDownloadAsBitmap
*%    *Option: TTFDownloadAsOutline
*%    {
*%        *rcNameID: =RC_STR_TRUETYPE_OUTLINE
*%    }
    *Option: TTFDownloadAsBitmap
    {
        *rcNameID: =RC_STR_TRUETYPE_BITMAP
    }
    *Option: TTFDownloadDisabled
    {
        *rcNameID: =RC_STR_TRUETYPE_DOWNLOADNONE
    }
}

*switch: TrueTypeFormat
{
*%    *case: TTFDownloadAsOutline
*%    {
*%        *FontFormat: HPPCL_OUTLINE
*%    }
    *case: TTFDownloadAsBitmap
    {
        *FontFormat: HPPCL
    }
    *case: TTFDownloadDisabled
    {
    }
}

*%======== StartPage (PCLXL) ========
*switch: ColorMode
{
    *case: Mono
    {
        *Command: CmdStartPage
        {
        *Order: PAGE_SETUP.30
        *Cmd: =real32_xy "<0000803f><0000803f>" =attr_ubyte =PageScale =SetPageScale
+             =ubyte =eGray =attr_ubyte =ColorSpace =SetColorSpace
        }
    }
    *case: 24bpp
    {
        *Command: CmdStartPage
        {
        *Order: PAGE_SETUP.30
        *Cmd: =real32_xy "<0000803f><0000803f>" =attr_ubyte =PageScale =SetPageScale
+             =ubyte =eRGB =attr_ubyte =ColorSpace =SetColorSpace
        }
    }
}

*%======== EndPage (PCL XL Only) ========
*switch: Collate
{
    *case: OFF
    {
        *switch: Stapling
        {
            *case: OFF
            {
                *Command: CmdEndPage
                {
                    *Order: PAGE_FINISH.10
*%                  *Cmd: =uint16 =NumOfCopy =attr_ubyte =PageCopies =EndPage
                    *CallbackID: =CMD_ENDPAGE_P6
                    *Params: LIST(NumOfCopies)
                }
            }
            *default:
            {
                *Command: CmdEndPage
                {
                    *Order: PAGE_FINISH.10
                    *Cmd: =uint16 "<0100>" =attr_ubyte =PageCopies =EndPage
                }
            }
        }
    }
    *case: ON
    {
        *Command: CmdEndPage
        {
            *Order: PAGE_FINISH.10
            *Cmd: =uint16 "<0100>" =attr_ubyte =PageCopies =EndPage
        }
    }
}

*%======== EndJob (PCLXL) ========
*Command: CmdEndJob
{
    *Order: JOB_FINISH.10
*%  *Cmd: =CloseDataSource =EndSession =PJL_ENDJOB
    *CallbackID: =CMD_ENDJOB_P6
}

*%======== Capabilities (PCLXL) ========
*EjectPageWithFF?: FALSE
*TextCaps: LIST(TC_CR_ANY,TC_CR_90,TC_SF_X_YINDEP,TC_SA_CONTIN,TC_IA_ABLE,TC_UA_ABLE)
*XMoveUnit: 1200
*YMoveUnit: 1200

*%======== Cursor Control (PCLXL) ========
*Command: CmdXMoveAbsolute { *Cmd: "" }
*Command: CmdXMoveRelRight
{
    *Cmd: ""
    *Params: LIST(DestXRel, TextXRes)
}
*Command: CmdXMoveRelLeft
{
    *Cmd: ""
    *Params: LIST(DestXRel, TextXRes)
}
*Command: CmdYMoveAbsolute
{
    *Cmd: ""
    *Params: LIST(DestY, TextYRes)
}
*Command: CmdYMoveRelDown
{
    *Cmd: ""
    *Params: LIST(DestYRel, TextYRes)
}
*Command: CmdYMoveRelUp
{
    *Cmd: ""
    *Params: LIST(DestYRel, TextYRes)
}
*Command: CmdCR { *Cmd: "" }
*Command: CmdLF { *Cmd: "" }
*Command: CmdFF { *Cmd: "" }

*%======== Font (PCLXL) ========
*MinFontID: 1
*%*MaxFontID: 65535
*MinGlyphID: 1
*MaxGlyphID: 1000
*%*FontFormat: HPPCL
*Command: CmdSetFontID { *Cmd : "" }
*Command: CmdSelectFontID
{
    *Cmd: ""
    *Params: LIST(FontHeight, CurrentFontID, TextYRes)
}
*Command: CmdSetCharCode { *Cmd : "" }
*Command: CmdBoldOn { *Cmd : "" }
*Command: CmdBoldOff { *Cmd : "" }
*Command: CmdSetAnyRotation
{
    *Cmd: ""
    *Params: LIST(PrintDirInCCDegrees)
}
*Command: CmdSetSimpleRotation
{
    *Cmd: ""
    *Params: LIST(PrintDirInCCDegrees)
}

*%======== Color (PCLXL) ========
*ChangeColorModeOnDoc?: FALSE

*%======== Selection Constraints (PCLXL) ========



*Else:  *% !RI_PCLXL

*%======== Resolution (PCL5c) ========
*Feature: Resolution
{
    *rcNameID: =RESOLUTION_DISPLAY
    *DefaultOption: 600dpi
    *Option: 600dpi
    {
        *rcNameID: =RC_STR_600DPI
        *DPI: PAIR(600, 600)
        *TextDPI: PAIR(600, 600)
        *MinStripBlankPixels: 32
        EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
        *SpotDiameter: 100
        *Command: CmdBeginRaster { *Cmd : "<1B>*v7S<1B>*r1A" }
        *Command: CmdEndRaster { *Cmd : "<1B>*rC" }
        *Command: CmdSendBlockData { *Cmd : "<1B>*b" %d{NumOfDataBytes}"W" }
        *switch: ColorMode
        {
            *case: 24bpp
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_LAST
                    *Cmd: "@PJL SET DATAMODE=COLOR<0A>@PJL SET RENDERMODE=COLOR<0A>"
+                         "@PJL SET RESOLUTION=600<0A>@PJL ENTER LANGUAGE=PCL<0A>"
+                         "<1B>E<1B>*t600R<1B>&u600D<1B>*r0F"
                }
            }
            *case: Mono
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_LAST
                    *Cmd: "@PJL SET DATAMODE=GRAYSCALE<0A>@PJL SET RENDERMODE=GRAYSCALE<0A>"
+                         "@PJL SET RESOLUTION=600<0A>@PJL ENTER LANGUAGE=PCL<0A>"
+                         "<1B>E<1B>*t600R<1B>&u600D<1B>*r0F"
                }
            }
        }
    }
    *Option: 300dpi
    {
        *rcNameID: =RC_STR_300DPI
        *DPI: PAIR(300, 300)
        *TextDPI: PAIR(300, 300)
        *MinStripBlankPixels: 32
        EXTERN_GLOBAL: *StripBlanks: LIST(ENCLOSED,TRAILING)
        *SpotDiameter: 100
        *Command: CmdBeginRaster { *Cmd : "<1B>*v7S<1B>*r1A" }
        *Command: CmdEndRaster { *Cmd : "<1B>*rC" }
        *Command: CmdSendBlockData { *Cmd : "<1B>*b" %d{NumOfDataBytes}"W" }
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_LAST
            *Cmd: "@PJL SET DATAMODE=GRAYSCALE<0A>@PJL SET RENDERMODE=GRAYSCALE<0A>"
+                 "@PJL SET RESOLUTION=300<0A>@PJL ENTER LANGUAGE=PCL<0A>"
+                 "<1B>E<1B>*t300R<1B>&u600D<1B>*r0F"
        }
    }
}

*%======== Gradation (PCL5c) ========
*Feature: Gradation
{
    *rcNameID: =RC_STR_GRADATION
    *HelpIndex: =HLP_GRADATION
    *DefaultOption: Standard
    *Option: Standard
    {
        *rcNameID: =RC_STR_STANDARD_2BPP
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_110
            *Cmd: "@PJL SET BITSPERDOT=2<0A>"     *% delete "@PJL SET GRADATION=STANDARD<0A>"
        }
        *Constraints: Resolution.300dpi
    }
    *Option: Fast
    {
        *rcNameID: =RC_STR_FAST_1BPP
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_110
            *Cmd: "@PJL SET BITSPERDOT=1<0A>"     *% delete "@PJL SET GRADATION=FAST<0A>"
        }
    }
}

*%======== Emit Orientation Command (CONCEALED) (PCL5c) ========
*% NOTE:
*% Need to write "*NoPageEject?: TRUE" in orientation command emission
*% to print mixed-orientation document in duplex correctly. (2002/07/06)

*Feature: EmitOrientationCommand
{
    *Name: "Emit Orientation Command"
    *ConcealFromUI?: TRUE
    *DefaultOption: Option1
    *Option: Option1
    {
        *Name: "Emit Orientation Command"
        *switch: Orientation
        {
            *case: PORTRAIT
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.25
                    *NoPageEject?: TRUE
                    *Cmd: =PCL5_ORIENTATION_PORT
                }
            }
            *case: LANDSCAPE_CC90
            {
                *Command: CmdSelect
                {
                    *Order: DOC_SETUP.25
                    *NoPageEject?: TRUE
                    *Cmd: =PCL5_ORIENTATION_LAND
                }
            }
        }
    }
}

