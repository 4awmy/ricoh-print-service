*%======== Hard Disk (CONCEALED) ========
*Feature: HardDisk
{
    *Name: "HardDisk"
    *ConcealFromUI?: TRUE
    *DefaultOption: Installed
    *Option: Installed
    {
        *Name: "Installed"
    }
}

*%======== Memory (CONCEALED) ========
*Feature: Memory
{
    *rcNameID: =PRINTER_MEMORY_DISPLAY
    *ConcealFromUI?: TRUE
    *DefaultOption: 65536KB
    *Option: 65536KB
    {
        *Name: "64MB"
        *MemoryConfigKB: PAIR(65536, 56700)
    }
}


*% #####################################################################


*%======== Finisher (installable option) ========
*Feature: Finisher
{
    *rcNameID: =RC_STR_FINISHER
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.FinisherShiftTray
        *Constraints: OutputBin.FinisherShiftTray1
        *Constraints: OutputBin.FinisherShiftTray2
        *Constraints: Stapling.TopLeft
        *Constraints: Stapling.TopRight
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and3holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.2and4holes
*Endif: *%%% !RICOH_AUTOCONFIG
*Ifdef: RICOH_AUTOCONFIG
*Else:  *%%% !RICOH_AUTOCONFIG
        *Constraints: PunchUnit.4holes
*Endif: *%%% !RICOH_AUTOCONFIG
        *DisabledFeatures: LIST(Stapling)
    }
    *Option: Finisher1000
    {
        *rcNameID: =RC_STR_FINISHER_1000
        *Constraints: OutputBin.FinisherShiftTray1
        *Constraints: OutputBin.FinisherShiftTray2
        *Constraints: Stapling.Top2
        *Constraints: Stapling.Left2
        *Constraints: Stapling.Right2
        *Constraints: PunchUnit.2and3holes
        *Constraints: PunchUnit.2and4holes
        *Constraints: PunchUnit.4holes
    }
    *Option: Finisher2250
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "2 Tray Finisher"
*Else:
        *rcNameID: =RC_STR_2TRAY_FINISHER
*Endif:
        *Constraints: OutputBin.FinisherShiftTray
    }
}

*%======== Punch Unit (installable option) ========
*Feature: PunchUnit
{
    *rcNameID: =RC_STR_PUNCH_UNIT
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and3holes
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "2 and 3 holes"
*Else:
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_3
*Endif:
        *Constraints: Punching.Left4
        *Constraints: Punching.Top4
        *Constraints: Punching.Right4
    }
    *Option: 2and4holes
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "2 and 4 holes"
*Else:
        *rcNameID: =RC_STR_PUNCH_UNIT_2_AND_4
*Endif:
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
    *Option: 4holes
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "4 holes"
*Else:
        *rcNameID: =RC_STR_PUNCH_UNIT_4
*Endif:
        *Constraints: Punching.Left2
        *Constraints: Punching.Top2
        *Constraints: Punching.Right2
        *Constraints: Punching.Left3
        *Constraints: Punching.Top3
        *Constraints: Punching.Right3
    }
}

*%======== Mailbox (installable option) ========
*Feature: Mailbox
{
    *rcNameID: =RC_STR_MAILBOX
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.OutputBin1
        *Constraints: OutputBin.OutputBin2
        *Constraints: OutputBin.OutputBin3
        *Constraints: OutputBin.OutputBin4
        *Constraints: OutputBin.OutputBin5
        *Constraints: OutputBin.OutputBin6
        *Constraints: OutputBin.OutputBin7
        *Constraints: OutputBin.OutputBin8
        *Constraints: OutputBin.OutputBin9
        *Constraints: OutputBin.MailboxProofTray
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}
*InvalidCombination: LIST(Finisher.Finisher1000, Mailbox.Installed)

*%======== External Output Tray (installable option) ========
*Feature: ExternalTray
{
    *rcNameID: =RC_STR_EXTERNAL_TRAY
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.ExternalTray
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}
*InvalidCombination: LIST(Finisher.Finisher1000, ExternalTray.Installed)
*InvalidCombination: LIST(Finisher.Finisher2250, ExternalTray.Installed)
*InvalidCombination: LIST(Mailbox.Installed, ExternalTray.Installed)

*%======== Inner Output Tray2 (installable option) ========
*Feature: InnerTray2
{
*Ifdef: USE_QUOTED_STRING
    *Name: "Internal Tray 2"
*Else:
    *rcNameID: =RC_STR_INTERNAL_TRAY2
*Endif:
    *FeatureType: PRINTER_PROPERTY
    *DefaultOption: NotInstalled
    *Option: NotInstalled
    {
        *rcNameID: =RC_STR_NOTINSTALLED
        *Constraints: OutputBin.InnerTray2
    }
    *Option: Installed
    {
        *rcNameID: =RC_STR_INSTALLED
    }
}

*%======== Orientation ========
*Feature: Orientation
{
    *rcNameID: =ORIENTATION_DISPLAY
    *DefaultOption: PORTRAIT
    *Option: PORTRAIT
    {
        *rcNameID: =PORTRAIT_DISPLAY
    }
    *Option: LANDSCAPE_CC90
    {
        *rcNameID: =LANDSCAPE_DISPLAY
    }
}

*%======== Duplex ========
*Feature: Duplex
{
    *rcNameID: =TWO_SIDED_PRINTING_DISPLAY
    *DefaultOption: NONE
    *Option: NONE
    {
        *rcNameID: =NONE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=OFF<0A>"
        }
    }
    *Option: VERTICAL
    {
        *rcNameID: =FLIP_ON_LONG_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=LONGEDGE<0A>"
        }
    }
    *Option: HORIZONTAL
    {
        *rcNameID: =FLIP_ON_SHORT_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=SHORTEDGE<0A>"
        }
    }
}

*%======== OutputBin ========
*Feature: OutputBin
{
    *rcNameID: =OUTPUTBIN_DISPLAY
    *HelpIndex: =HLP_OUTPUTBIN
    *DefaultOption: PrinterDefault
    *Option: PrinterDefault
    {
        *rcNameID: =RC_STR_PRINTER_DEFAULT
    }
    *Option: InnerTray1
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Internal Tray 1"
*Else:
        *rcNameID: =RC_STR_INTERNAL_TRAY1
*Endif:
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=UPPER<0A>"
        }
    }
    *Option: InnerTray2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Internal Tray 2"
*Else:
        *rcNameID: =RC_STR_INTERNAL_TRAY2
*Endif:
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=INNER<0A>"
        }
    }
    *Option: ExternalTray
    {
        *rcNameID: =RC_STR_EXTERNAL_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=LOWER<0A>"
        }
    }
    *Option: FinisherShiftTray
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
