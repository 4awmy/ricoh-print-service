        }
    }
    *Option: OutputBin3
    {
        *rcNameID: =RC_STR_MAILBOX_TRAY3
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=OPTIONALOUTPUTBIN4<0A>"
        }
    }
    *Option: OutputBin4
    {
        *rcNameID: =RC_STR_MAILBOX_TRAY4
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
