*%======== Collate ========
*Feature: Collate
{
    *Name: "Collated"       *%%% This string isn't used in UI.
    *DefaultOption: OFF
    *Option: ON
    {
        *rcNameID: =ON_DISPLAY
        *switch: Finisher
        {
            *case: NotInstalled
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
                    *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET JOBOFFSET=ROTATE<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
                    *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET JOBOFFSET=SHIFT<0A>"
                }
            }
        }
    }
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *switch: Finisher
        {
            *case: NotInstalled
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
*%                  *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
                    *CallbackID: =CMD_COLLATE_JOBOFFSET_ROTATE
                    *Params: LIST(NumOfCopies)
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_50
*%                  *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
                    *CallbackID: =CMD_COLLATE_JOBOFFSET_SHIFT
                    *Params: LIST(NumOfCopies)
                }
            }
        }
    }
}

*%======== Stapling ========
*Macros: CmdStrings_Stapling
{
    PRECMD_STAPLE: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERSHIFT<0A>@PJL SET JOBOFFSET=OFF<0A>"
    PRECMD_STAPLE_PROOF: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERPROOF<0A>@PJL SET JOBOFFSET=OFF<0A>"
}
*Feature: Stapling
{
    *rcNameID: =RC_STR_STAPLE
    *HelpIndex: =HLP_STAPLE
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_60
            *Cmd: "@PJL SET STAPLE=OFF<0A>"
        }
    }
    *Option: TopLeft
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Top Left"
*Else:
        *rcNameID: =RC_STR_TOP_LEFT
*Endif:
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
        }
    }
    *Option: TopRight
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Top Right"
*Else:
        *rcNameID: =RC_STR_TOP_RIGHT
*Endif:
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
        }
    }
    *Option: Left2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Left 2"
*Else:
        *rcNameID: =RC_STR_LEFT2
*Endif:
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
        }
    }
    *Option: Top2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Top 2"
*Else:
        *rcNameID: =RC_STR_TOP2
*Endif:
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
        }
    }
    *Option: Right2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Right 2"
*Else:
        *rcNameID: =RC_STR_RIGHT2
*Endif:
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
        }
    }
}

*%======== Punching (custom feature) ========
*Macros: CmdStrings_Punching
{
    PRECMD_PUNCH: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
    PRECMD_PUNCH_PROOF: "@PJL SET OUTBIN=FINISHERPROOF<0A>"
}
*Feature: Punching
{
    *rcNameID: =RC_STR_PUNCH
    *HelpIndex: =HLP_PUNCH
    *FeatureType: DOC_PROPERTY
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_70
            *Cmd: "@PJL SET PUNCH=OFF<0A>"
        }
    }
    *Option: Left2
    {
*Ifdef: USE_QUOTED_STRING
        *Name: "Left 2"
*Else:
        *rcNameID: =RC_STR_LEFT2
*Endif:
        *switch: PunchUnit
        {
            *case: 2and4holes
            {
                *switch: OutputBin
                {
                    *case: FinisherShiftTray1
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH_PROOF "@PJL SET PUNCH=LEFTPORT<0A>@PJL SET PUNCHHOLE=JP2<0A>"
                        }
                    }
                    *default:
                    {
                        *Command: CmdSelect
                        {
