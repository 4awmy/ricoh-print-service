*%======== Duplex ========
*Feature: Duplex
{
    *rcNameID: =TWO_SIDED_PRINTING_DISPLAY
    *DefaultOption: NONE
    *Option: NONE
    {
        *rcNameID: =NONE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=OFF<0A>"
        }
    }
    *Option: VERTICAL
    {
        *rcNameID: =FLIP_ON_LONG_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=LONGEDGE<0A>"
        }
    }
    *Option: HORIZONTAL
    {
        *rcNameID: =FLIP_ON_SHORT_EDGE_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_15
            *Cmd: "@PJL SET DUPLEX=ON<0A>@PJL SET BINDING=SHORTEDGE<0A>"
        }
    }
}

*%======== OutputBin ========
*Feature: OutputBin
{
    *rcNameID: =OUTPUTBIN_DISPLAY
    *HelpIndex: =HLP_OUTPUTBIN
    *DefaultOption: PrinterDefault
    *Option: PrinterDefault
    {
        *rcNameID: =RC_STR_PRINTER_DEFAULT
    }
    *Option: StandardTray
    {
        *rcNameID: =RC_STR_STANDARD_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=UPPER<0A>"
        }
    }
    *Option: ExternalTray
    {
        *rcNameID: =RC_STR_EXTERNAL_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=LOWER<0A>"
        }
    }
    *Option: FinisherShiftTray1
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY1
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERPROOF<0A>"
        }
    }
    *Option: FinisherShiftTray2
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY2
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
        }
    }
    *Option: FinisherShiftTray
    {
        *rcNameID: =RC_STR_FINISHER_SHIFT_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=FINISHERSHIFT<0A>"
        }
    }
    *Option: FinisherBookletTray
    {
        *rcNameID: =RC_STR_BOOKLET_FINISHER_TRAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
	    *Cmd: "@PJL SET OUTBIN=FINISHERBOOKLET<0A>"
        }
    }
    *Option: LeftTray1
    {
        *rcNameID: =RC_STR_LEFT_TRAY1
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=LOWER2<0A>"
        }
    }
    *Option: LeftTray2
    {
        *rcNameID: =RC_STR_LEFT_TRAY2
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_40
            *Cmd: "@PJL SET OUTBIN=LOWER3<0A>"
        }
    }
}

*%======== Collate ========
*Feature: Collate
{
    *Name: "Collated"       *%%% This string isn't used in UI.
    *DefaultOption: OFF
    *Option: ON
    {
        *rcNameID: =ON_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_50
            *Cmd: "@PJL SET QTY=" %d{NumOfCopies}"<0A>"
        }
    }
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_50
*%          *Cmd: "@PJL SET JOBOFFSET=OFF<0A>"
            *CallbackID: =CMD_COLLATE_JOBOFFSET_OFF
            *Params: LIST(NumOfCopies)
        }
    }
}

*%======== Stapling ========
*Macros: CmdStrings_Stapling
{
    PRECMD_STAPLE: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERSHIFT<0A>@PJL SET JOBOFFSET=OFF<0A>"
    PRECMD_STAPLE_PROOF: "@PJL SET QTY=" %d{NumOfCopies}"<0A>@PJL SET OUTBIN=FINISHERPROOF<0A>@PJL SET JOBOFFSET=OFF<0A>"
}
*Feature: Stapling
{
    *rcNameID: =RC_STR_STAPLE
    *HelpIndex: =HLP_STAPLE
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_60
            *Cmd: "@PJL SET STAPLE=OFF<0A>"
        }
    }
    *Option: TopLeft
    {
        *rcNameID: =RC_STR_TOP_LEFT
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFTTOP<0A>"
                }
            }
        }
    }
    *Option: TopRight
    {
        *rcNameID: =RC_STR_TOP_RIGHT
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHTTOP<0A>"
                }
            }
        }
    }
    *Option: Left2
    {
        *rcNameID: =RC_STR_LEFT2
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFT2PORT<0A>"
                }
            }
        }
    }
    *Option: Top2
    {
        *rcNameID: =RC_STR_TOP2
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=TOP2PORT<0A>"
                }
            }
        }
    }
    *Option: Right2
    {
        *rcNameID: =RC_STR_RIGHT2
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=RIGHT2PORT<0A>"
                }
            }
        }
    }
    *Option: TopLeftSlant
    {
        *rcNameID: =RC_STR_TOP_LEFT_SLANT
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=LEFTTOPSLANTPORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE "@PJL SET STAPLE=LEFTTOPSLANTPORT<0A>"
                }
            }
        }
    }
    *Option: TopRightSlant
    {
        *rcNameID: =RC_STR_TOP_RIGHT_SLANT
        *switch: OutputBin
        {
            *case: FinisherShiftTray1
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
                    *Cmd: =PRECMD_STAPLE_PROOF "@PJL SET STAPLE=RIGHTTOPSLANTPORT<0A>"
                }
            }
            *default:
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_60
