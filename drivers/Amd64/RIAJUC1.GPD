        *switch: PunchUnit
        {
            *case: 2and4holes
            {
                *switch: OutputBin
                {
                    *case: FinisherShiftTray1
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH_PROOF "@PJL SET PUNCH=TOPPORT<0A>@PJL SET PUNCHHOLE=JP2<0A>"
                        }
                    }
                    *default:
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH "@PJL SET PUNCH=TOPPORT<0A>@PJL SET PUNCHHOLE=JP2<0A>"
                        }
                    }
                }
            }
            *default:
            {
                *switch: OutputBin
                {
                    *case: FinisherShiftTray1
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH_PROOF "@PJL SET PUNCH=TOPPORT<0A>@PJL SET PUNCHHOLE=US2<0A>"
                        }
                    }
                    *default:
                    {
                        *Command: CmdSelect
                        {
                            *Order: =PJL_SETUP_70
                            *Cmd: =PRECMD_PUNCH "@PJL SET PUNCH=TOPPORT<0A>@PJL SET PUNCHHOLE=US2<0A>"
                        }
                    }
                }
            }
        }
    }
    *Option: Right2
