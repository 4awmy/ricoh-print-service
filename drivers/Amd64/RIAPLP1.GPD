*%======== Slip Sheet (custom feature) ========
*Feature: SlipSheet
{
*Ifdef: USE_QUOTED_STRING
    *Name: "Slip Sheet"
*Else:
    *rcNameID: =RC_STR_SLIPSHEET
*Endif:
    *HelpIndex: =HLP_SLIPSHEET
    *ConflictPriority: 10
    *DefaultOption: OFF
    *Option: OFF
    {
        *rcNameID: =OFF_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_90
            *Cmd: "@PJL SET SLIPSHEETPRINT=OFF<0A>"
        }
    }
    *Option: ON
    {
        *rcNameID: =ON_DISPLAY
        *Command: CmdSelect
        {
            *Order: =PJL_SETUP_90
            *Cmd: "@PJL SET SLIPSHEETPRINT=OFF<0A>"
        }
    }
}

*%======== Slip Sheet InputBin (custom feature) ========
*Feature: SlipSheetInputBin
{
*Ifdef: USE_QUOTED_STRING
    *Name: "Slip Sheet Paper Source"
*Else:
    *rcNameID: =RC_STR_SLIPSHEET_PAPER_SOURCE
*Endif:
    *HelpIndex: =HLP_SLIPSHEET_PAPER_SOURCE
    *DefaultOption: Tray1
    *Option: Tray1
    {
        *rcNameID: =RC_STR_TRAY1
        *switch: SlipSheet
        {
            *case: ON
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_100
                    *Cmd: "@PJL SET SLIPSHEETPRINTTRAY=TRAY1<0A>"
                }
            }
        }
    }
    *Option: Tray2
    {
        *rcNameID: =RC_STR_TRAY2
        *switch: SlipSheet
        {
            *case: ON
            {
                *Command: CmdSelect
                {
                    *Order: =PJL_SETUP_100
                    *Cmd: "@PJL SET SLIPSHEETPRINTTRAY=TRAY2<0A>"
                }
            }
        }
    }
}

