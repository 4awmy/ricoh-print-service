*InvalidCombination: LIST(SlipSheet.ON, MediaType.Auto)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.STANDARD)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Recycled)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Special)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Thick)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Color)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.GLOSSY)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Letterhead)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Preprinted)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Labels)
*InvalidCombination: LIST(SlipSheet.ON, MediaType.Cardstock)
*InvalidCombination: LIST(SlipSheet.ON, Duplex.VERTICAL)
*InvalidCombination: LIST(SlipSheet.ON, Duplex.HORIZONTAL)

*InvalidCombination: LIST(MediaType.Thick, Duplex.VERTICAL)
*InvalidCombination: LIST(MediaType.Thick, Duplex.HORIZONTAL)
*InvalidCombination: LIST(MediaType.TRANSPARENCY, Duplex.VERTICAL)
*InvalidCombination: LIST(MediaType.TRANSPARENCY, Duplex.HORIZONTAL)
*InvalidCombination: LIST(MediaType.GLOSSY, Duplex.VERTICAL)
*InvalidCombination: LIST(MediaType.GLOSSY, Duplex.HORIZONTAL)
*InvalidCombination: LIST(MediaType.Labels, Duplex.VERTICAL)
*InvalidCombination: LIST(MediaType.Labels, Duplex.HORIZONTAL)

